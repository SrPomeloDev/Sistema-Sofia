# ─────────────────────────────────────────────────────────────────────
# Configuración de la aplicación Gestión de Camiones
# Copia este archivo como .env y completa los valores reales.
# ─────────────────────────────────────────────────────────────────────

# ── OPCIÓN 1: Google Apps Script Web App (RECOMENDADA) ──────────────
# Despliega Code.gs en script.google.com como Web App y pega aquí la URL.
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwzCNT-yZr53x0THKRhrvjDc_7j_SxGI750AHAUp6ZVNXrVb-zwjpOqKz07vh1BLUmt/exec

# Token definido en Code.gs (API_TOKEN). Cámbialo por uno seguro.
APPS_SCRIPT_TOKEN=pablo9090

# ── OPCIÓN 2: Service Account (fallback si no usas Apps Script) ────
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account",...}'
# SHEET_ID=tu-sheet-id
# SHEET_NAME=Hoja1

# ── Opcionales (valores por defecto) ───────────────────────────────
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW=10
# MAX_RETRIES=3
# RETRY_BASE_DELAY=1.0
